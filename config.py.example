# ============ 数据库配置 ============
# SQLite 数据库配置（通常无需修改）
DB_INIT_SQL = """
CREATE TABLE IF NOT EXISTS anime (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    name_jp TEXT,
    year INTEGER,
    cover_image_url TEXT,
    status TEXT DEFAULT 'pending',  -- pending: 待爬取, crawling: 爬取中, completed: 已完成, failed: 失败
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE IF NOT EXISTS lyrics (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    anime_id INTEGER NOT NULL,
    song_name TEXT NOT NULL,
    song_name_cn TEXT,
    song_type TEXT,  -- OP, ED, IN, TM
    singer TEXT,
    language TEXT DEFAULT 'ja',  -- ja: 日语, en: 英语, zh: 中文, etc.
    lyrics_text TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (anime_id) REFERENCES anime(id)
);

CREATE TABLE IF NOT EXISTS articles (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    lyrics_id INTEGER NOT NULL,
    article_title TEXT,
    article_content TEXT,
    cover_image_path TEXT,
    wechat_media_id TEXT,  -- 微信素材ID
    wechat_article_id TEXT,  -- 微信草稿ID
    status TEXT DEFAULT 'draft',  -- draft: 草稿, published: 已发布
    published_at TIMESTAMP,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (lyrics_id) REFERENCES lyrics(id)
);

CREATE TABLE IF NOT EXISTS task_logs (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    task_type TEXT NOT NULL,  -- weekly_crawl, daily_publish
    status TEXT DEFAULT 'running',  -- running, success, failed
    message TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE IF NOT EXISTS used_anime_images (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    anime_name TEXT NOT NULL,     -- 动画中文名（作为文件夹名）
    image_url TEXT NOT NULL,      -- 图片源 URL（唯一约束，防止重复记录）
    image_path TEXT NOT NULL,     -- 本地文件路径
    hash_value TEXT,              -- 图片感知哈希（aHash，存储为字符串避免 SQLite int 溢出）
    used_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    UNIQUE(anime_name, image_url)
);
"""
