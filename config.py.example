# 每句歌词最大分析长度（字符数）
MAX_LYRICS_LINE_LENGTH = 200

# 文章标题模板
ARTICLE_TITLE_TEMPLATE = "边听歌边学日语系列：{anime_name}-{song_name}"

# ============ LLM 配置（用于歌词分析和语法解析）===========
